---
layout: base
---

<div class="startup-profile-container" style="max-width: 900px; margin: 3rem auto; padding: 0 1.5rem; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;">
  
  <!-- Breadcrumb Navigation -->
  <nav style="margin-bottom: 1.5rem; font-size: 14px;">
    <a href="/startups/" style="color: #ff6600; text-decoration: none; font-weight: 500;">&larr; Back to Directory</a>
  </nav>

  <!-- Hero Row Grid -->
  <header style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1.5rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 2rem; margin-bottom: 2.5rem;">
    <div style="display: flex; gap: 1.25rem; align-items: center;">
      <div style="width: 64px; height: 64px; background: #f1f5f9; border-radius: 8px; display: flex; align-items: center; justify-content: center; border: 1px solid #cbd5e1; flex-shrink: 0;">
        <span style="font-size: 16px; font-weight: 800; color: #64748b;">{{ name.slice(0, 2) | upper }}</span>
      </div>
      <div>
        <h1 style="font-size: 32px; font-weight: 800; color: #0f172a; margin: 0; letter-spacing: -0.025em;">{{ name }}</h1>
        <p style="margin: 0.25rem 0 0 0; font-size: 16px; color: #475569; font-weight: 500;">{{ location }}</p>
      </div>
    </div>
    
    <div>
      <a href="{{ website }}" target="_blank" rel="noopener noreferrer" style="display: inline-block; background: #ff6600; color: #fff; padding: 0.6rem 1.2rem; border-radius: 6px; font-weight: 600; text-decoration: none; font-size: 14px;">Visit Website</a>
    </div>
  </header>

  <!-- Content Split Grid -->
  <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 3rem; align-items: flex-start;">
    
    <!-- Rich Text Markdown Section -->
    <main class="markdown" style="line-height: 1.7; color: #334155;">
      <p style="font-size: 18px; font-weight: 500; color: #0f172a; line-height: 1.5; margin-bottom: 2rem; border-left: 3px solid #ff6600; padding-left: 1rem;">
        {{ summary }}
      </p>
      
      <!-- This loops in all your markdown text elements seamlessly -->
      {{ content | safe }}
    </main>

    <!-- Meta Details Sidebar Card -->
    <aside style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 1.25rem; position: sticky; top: 2rem;">
      <h3 style="font-size: 14px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 1rem 0; border-bottom: 1px solid #e2e8f0; padding-bottom: 0.5rem;">Company Details</h3>
      
      <div style="display: flex; flex-direction: column; gap: 0.85rem; font-size: 14px;">
        <div>
          <span style="color: #64748b; display: block; font-size: 12px; font-weight: 500;">Genre</span>
          <strong style="color: #334155; font-weight: 600;">{{ genre }}</strong>
        </div>
        <div>
          <span style="color: #64748b; display: block; font-size: 12px; font-weight: 500;">Established</span>
          <strong style="color: #334155; font-weight: 600;">{{ established }}</strong>
        </div>
        <div>
          <span style="color: #64748b; display: block; font-size: 12px; font-weight: 500;">Funding Status</span>
          <strong style="color: #334155; font-weight: 600;">{{ funding }}</strong>
        </div>
        <div>
          <span style="color: #64748b; display: block; font-size: 12px; font-weight: 500;">Team Size</span>
          <strong style="color: #334155; font-weight: 600;">{{ teamSize }}</strong>
        </div>
      </div>
    </aside>

  </div>
</div>