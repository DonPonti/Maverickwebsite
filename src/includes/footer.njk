<footer class="footer h-card" role="contentinfo">
    <div class="footer__inner container">
        <p class="footer__item">
            <strong>&copy; 2026&ndash;{{ build.timestamp | dateToFormat('yyyy') }}</strong><br />
            <a class="p-name u-url" rel="me" href="{{ site.url }}">{{ site.title }}</a>
        </p>

        <p class="footer__item">
            <strong>Ecosystem</strong><br />
            <a href="/startups/">Startup Directory</a>
        </p>

        <p class="footer__item">
            <strong>Legal</strong><br />
            <a href="/privacy/">Privacy Policy</a> / 
            <a href="/legal/">Legal Notice</a>
        </p>

        <!-- Untouched Speedlify Score Widget Section -->
        <p class="footer__item footer__item--right u-desktop-only">
            <a href="https://speedlify.mxb.dev/mxb.dev/" class="footer__speedlify">
                <speedlify-score speedlify-url="https://speedlify.mxb.dev" hash="7dda0135" score weight></speedlify-score>
            </a>
        </p>

        <p class="footer__item footer__item--right">
            <a href="https://x.com/mavericktimesin" class="footer__icon" title="Follow Maverick Times on X" target="_blank" rel="noopener noreferrer">
    <span class="sr-only">Follow us on X (Twitter)</span>
    {% icon "twitter" %}
</a>
            <a href="{{ '/feed.xml' | url }}" class="footer__icon" title="RSS Feed">
                <span class="sr-only">RSS Feed</span>
                {% icon "feed" %}
            </a>
        </p>

    </div>
</footer>