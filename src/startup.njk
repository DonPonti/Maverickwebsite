---
layout: base.njk
title: Startup Directory
permalink: /startups/
eleventyNavigation:
  key: Startups
  order: 2
---

<style>
  /* Page Theme Background Sync from 1000069438.png */
  body {
    background-color: #fbf9f4 !important;
  }

  .yc-container {
    max-width: 700px; /* Kept tight and centered like the mobile layout views */
    margin: 2rem auto;
    padding: 0 1rem;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  /* Elegant Italic Main Header */
  .yc-main-title {
    font-family: 'Noe Display', Georgia, serif;
    font-style: italic;
    font-size: 42px;
    font-weight: 400;
    text-align: center;
    color: #000000;
    margin-bottom: 1.5rem;
  }

  .yc-description {
    font-size: 17px;
    color: #111111;
    text-align: center;
    line-height: 1.5;
    margin-bottom: 2rem;
    padding: 0 0.5rem;
  }

  /* Sort Control Area */
  .yc-sort-container {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 0.5rem;
    font-size: 15px;
    color: #000000;
    margin-bottom: 1rem;
  }

  .yc-select {
    padding: 0.5rem 2rem 0.5rem 0.75rem;
    border-radius: 4px;
    border: 1px solid #ccc;
    background: #fff;
    font-size: 15px;
    cursor: pointer;
  }

  /* Search Input layout styling */
  .yc-search-box {
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 8px;
    padding: 1.25rem;
    margin-bottom: 1.5rem; /* Increased margin slightly since filter button is gone */
    box-shadow: 0 1px 2px rgba(0,0,0,0.05);
  }

  .yc-input {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid #3b82f6; /* Native blue boundary line focus border from example */
    border-radius: 6px;
    font-size: 16px;
    outline: none;
    box-sizing: border-box;
  }

  .yc-meta-count {
    font-size: 13.5px;
    color: #555;
    margin-bottom: 1rem;
  }

  /* Seamless Row Wrapper matching 1000069439.jpg */
  .yc-list {
    background: #fff;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    overflow: hidden;
  }

  .yc-row {
    display: flex;
    align-items: flex-start;
    padding: 1.25rem 1rem;
    border-bottom: 1px solid #e5e5e5;
    background: #fff;
  }

  .yc-row:last-child {
    border-bottom: none;
  }

  /* Circle Logo Avatar Frame */
  .yc-avatar-circle {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: #fff0f3;
    border: 1px solid #ffe3e8;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: 1.25rem;
  }

  .yc-avatar-text {
    font-size: 14px;
    font-weight: 700;
    color: #ff335f;
  }

  .yc-content {
    flex-grow: 1;
  }

  /* Inline Identity Header */
  .yc-title-bar {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .yc-company-name {
    font-size: 18px;
    font-weight: 700;
    color: #000000;
    text-decoration: none;
  }

  .yc-company-location {
    font-size: 13px;
    color: #555555;
  }

  .yc-company-summary {
    font-size: 15px;
    color: #111111;
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  /* Capsule Pill Tags system matching screenshots */
  .yc-tag-group {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .yc-pill {
    display: inline-flex;
    align-items: center;
    background: #eae6db; /* Authentic muted gray-brown badge tone */
    color: #222222;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* Mini dynamic brand block matching the screenshot's 'Y' label indicator */
  .yc-pill-prefix {
    width: 8px;
    height: 8px;
    background: #ff335f; /* Your custom Leaf Pink */
    margin-right: 4px;
    border-radius: 1px;
    display: inline-block;
  }
</style>

<div class="yc-container">
  
  <h1 class="yc-main-title">Startup Directory</h1>
  
  <p class="yc-description">
    Since 2026, we have tracked emerging local ecosystems across major tech corridors, highlighting growth playbooks and active regional metrics.
  </p>

  <!-- Sort Row -->
  <div class="yc-sort-container">
    <span>Sort by</span>
    <select id="sortDirectory" class="yc-select">
      <option value="rank">Default</option>
      <option value="alpha">Alphabetical (A-Z)</option>
      <option value="location">Location</option>
    </select>
  </div>

  <!-- Search Input Container -->
  <div class="yc-search-box">
    <input type="text" placeholder="Search..." class="yc-input" disabled value="">
  </div>

  <div class="yc-meta-count">
    Showing {{ collections.startups | length }} of {{ collections.startups | length }}+ companies
  </div>

  <!-- Perfectly Framed Directory Rows Block -->
  <div id="directoryList" class="yc-list">
    {% for item in collections.startups %}
    <div class="company-row yc-row" data-rank="{{ loop.index }}" data-name="{{ item.data.name }}" data-location="{{ item.data.location }}">
      
      <!-- Perfect Left-Aligned Circle Profile Avatar -->
      <div class="yc-avatar-circle">
        <span class="yc-avatar-text">{{ item.data.name.slice(0, 2) | upper }}</span>
      </div>
      
      <!-- Content Processing Space -->
      <div class="yc-content">
        <div class="yc-title-bar">
          <a href="{{ item.url }}" class="yc-company-name">{{ item.data.name }}</a>
          <span class="yc-company-location">{{ item.data.location }}</span>
        </div>
        
        <p class="yc-company-summary">{{ item.data.summary }}</p>
        
        <!-- Replicated Muted Capsule Tags -->
        <div class="yc-tag-group">
          <div class="yc-pill">
            <span class="yc-pill-prefix"></span>
            Batch {{ loop.index }}
          </div>
          <div class="yc-pill">{{ item.data.genre }}</div>
        </div>
      </div>

    </div>
    {% endfor %}
  </div>

</div>

<!-- Sorting logic script -->
<script>
  document.getElementById('sortDirectory').addEventListener('change', function(e) {
    const list = document.getElementById('directoryList');
    const rows = Array.from(list.getElementsByClassName('company-row'));
    const criteria = e.target.value;

    rows.sort((a, b) => {
      if (criteria === 'rank') {
        return parseInt(a.getAttribute('data-rank')) - parseInt(b.getAttribute('data-rank'));
      } else if (criteria === 'alpha') {
        return a.getAttribute('data-name').localeCompare(b.getAttribute('data-name'));
      } else if (criteria === 'location') {
        return a.getAttribute('data-location').localeCompare(b.getAttribute('data-location'));
      }
    });

    rows.forEach(row => list.appendChild(row));
  });
</script>