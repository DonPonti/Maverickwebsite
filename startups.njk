---
layout: layouts/home.njk
title: Startups
permalink: /startups/
templateClass: tmpl-home-startups
description: A directory of startups building out of Hyderabad and Warangal.
eleventyNavigation:
  key: Startups
  order: 1
---
{% from "startuprow.njk" import row with context %}
{% from "gateway.njk" import gateway %}

<section class="hero hero-compact">
  {{ gateway() }}
  <p class="eyebrow">Directory &middot; Hyderabad &amp; Warangal</p>
  <h2 class="hero-headline">The full list.</h2>
  <p class="tagline">
    {{ startups.length }} startups, sorted by city. This is sample data &mdash;
    <a href="mailto:hello@example.com?subject=Add%20a%20startup">submit yours</a> to be added.
  </p>
</section>

<section class="directory">
  <h2 class="city-heading">Hyderabad</h2>
  {% for s in startups %}
    {% if s.location == "Hyderabad" %}{{ row(s) }}{% endif %}
  {% endfor %}

  <h2 class="city-heading">Warangal</h2>
  {% for s in startups %}
    {% if s.location == "Warangal" %}{{ row(s) }}{% endif %}
  {% endfor %}
</section>
