---
layout: layouts/home.njk
title: "Startups Directory - Hyderabad & Warangal"
permalink: /startups/
---

<div class="yc-directory-envelope">
  <header class="yc-dir-header">
    <div class="yc-site-name">Maaverick Times</div>
    <div class="yc-subtitle">Startups Directory</div>
  </header>

  <div class="yc-filter-bar">
    <span class="filter-label">Filter Region:</span>
    <button class="yc-filter-btn active" onclick="applyCityFilter('all', this)">All Eco-systems</button>
    <button class="yc-filter-btn" onclick="applyCityFilter('Hyderabad', this)">Hyderabad</button>
    <button class="yc-filter-btn" onclick="applyCityFilter('Warangal', this)">Warangal</button>
  </div>

  <div class="yc-list-container">
    {% for startup in collections.startups %}
      <div class="yc-startup-row" data-city="{{ startup.data.city }}">
        
        <div class="yc-row-img-box">
          {{ startup.data.name | truncate(2, true, "") | upper }}
        </div>
        
        <div class="yc-row-details">
          <div class="yc-row-topline">
            <a href="{{ startup.url }}" class="yc-startup-name-link">{{ startup.data.name }}</a>
            <div class="yc-row-meta">
              <span class="mini-tag loc">{{ startup.data.city }}</span>
              <span class="mini-tag sec">{{ startup.data.sector }}</span>
            </div>
          </div>
          <p class="yc-row-tagline">{{ startup.data.tagline }}</p>
          <div class="yc-row-footer-metrics">
            <span>Stage: <strong>{{ startup.data.stage }}</strong></span>
            <a href="{{ startup.data.website }}" target="_blank" rel="noopener" class="yc-row-external">Launch Site ↗</a>
          </div>
        </div>

      </div>
    {% endfor %}
  </div>
</div>

<style>
  .yc-directory-envelope { max-width: 850px; margin: 3rem auto; padding: 0 1rem; font-family: -apple-system, BlinkMacSystemFont, "Inter", sans-serif; }
  .yc-dir-header { text-align: center; margin-bottom: 2.5rem; }
  .yc-site-name { font-size: 0.9rem; text-transform: uppercase; font-weight: 700; letter-spacing: 0.15em; color: #6b7280; margin-bottom: 0.25rem; }
  .yc-subtitle { font-size: 2.25rem; font-weight: 800; color: #111827; letter-spacing: -0.03em; }
  .yc-filter-bar { background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 0.75rem 1.25rem; display: flex; align-items: center; gap: 0.75rem; margin-bottom: 2rem; }
  .filter-label { font-size: 0.85rem; font-weight: 600; color: #4b5563; margin-right: 0.5rem; }
  .yc-filter-btn { background: transparent; border: none; padding: 0.4rem 0.85rem; border-radius: 6px; font-size: 0.85rem; font-weight: 500; color: #4b5563; cursor: pointer; transition: all 0.15s; }
  .yc-filter-btn:hover { background: #f3f4f6; color: #111827; }
  .yc-filter-btn.active { background: #fff; color: #f97316; font-weight: 600; box-shadow: 0 1px 2px rgba(0,0,0,0.05); border: 1px solid #e5e7eb; }
  .yc-list-container { display: flex; flex-direction: column; gap: 0.75rem; }
  .yc-startup-row { display: flex; gap: 1.25rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 1.25rem; transition: border-color 0.15s, box-shadow 0.15s; }
  .yc-startup-row:hover { border-color: #d1d5db; box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .yc-row-img-box { width: 56px; height: 56px; background: #f3f4f6; border-radius: 6px; border: 1px solid #e5e7eb; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #6b7280; font-size: 1.1rem; flex-shrink: 0; }
  .yc-row-details { flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
  .yc-row-topline { display: flex; justify-content: space-between; align-items: center; }
  .yc-startup-name-link { font-size: 1.2rem; font-weight: 700; color: #111827; text-decoration: none !important; }
  .yc-startup-name-link:hover { color: #f97316; }
  .yc-row-meta { display: flex; gap: 0.4rem; }
  .mini-tag { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 4px; text-transform: uppercase; }
  .mini-tag.loc { background: #f3f4f6; color: #374151; }
  .mini-tag.sec { background: #ecfdf5; color: #047857; }
  .yc-row-tagline { margin: 0.35rem 0 0.75rem 0; color: #4b5563; font-size: 0.95rem; line-height: 1.4; }
  .yc-row-footer-metrics { display: flex; justify-content: space-between; align-items: center; font-size: 0.8rem; color: #9ca3af; border-top: 1px dotted #f3f4f6; padding-top: 0.5rem; }
  .yc-row-footer-metrics strong { color: #4b5563; }
  .yc-row-external { color: #f97316; text-decoration: none !important; font-weight: 500; }
</style>

<script>
function applyCityFilter(city, buttonEl) {
  document.querySelectorAll('.yc-filter-btn').forEach(btn => btn.classList.remove('active'));
  buttonEl.classList.add('active');

  const rows = document.querySelectorAll('.yc-startup-row');
  rows.forEach(row => {
    if (city === 'all' || row.getAttribute('data-city') === city) {
      row.style.display = 'flex';
    } else {
      row.style.display = 'none';
    }
  });
}
</script>