---
title: Telangana Startups
layout: layouts/home.njk
templateClass: tmpl-home-index
description: A minimal directory and blog tracking startups building out of Hyderabad and Warangal.
date: Last Modified
---
{% from "startuprow.njk" import row with context %}
{% from "gateway.njk" import gateway %}

<section class="hero">
  {{ gateway() }}
  <p class="eyebrow">Directory &middot; Hyderabad &amp; Warangal</p>
  <h2 class="hero-headline">A registry of startups<br>building out of Telangana.</h2>
  <p class="tagline">
    Fintech, SaaS, agritech, and everything in between &mdash; tracked in one
    minimal, no-nonsense list.
  </p>
  <div class="actions">
    <a class="btn btn-primary" href="/startups/">Browse the directory</a>
    <a class="btn" href="mailto:hello@example.com?subject=Add%20our%20startup">Submit a startup</a>
  </div>
  <dl class="stat-strip">
    <div><dt>{{ startupStats.total }}</dt><dd>Startups</dd></div>
    <div><dt>{{ startupStats.cities }}</dt><dd>Cities</dd></div>
    <div><dt>{{ startupStats.sectors }}</dt><dd>Sectors</dd></div>
  </dl>
</section>

<section class="directory">
  <div class="directory-toolbar">
    <h2>Recently added</h2>
    <a href="/startups/">View all {{ startups.length }} &rarr;</a>
  </div>
  {% for s in startups %}
    {% if loop.index0 < 6 %}{{ row(s) }}{% endif %}
  {% endfor %}
</section>

<section class="directory" id="posts">
  <div class="directory-toolbar">
    <h2>From the blog</h2>
    <a href="/posts/">Archive &rarr;</a>
  </div>
  {% set postslist = collections.posts %}
  {% include "postslist.njk" %}
</section>
